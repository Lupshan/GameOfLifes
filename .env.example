# GameOfLifes — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# Required — compose will refuse to start without these
POSTGRES_PASSWORD=          # openssl rand -hex 24
JWT_SECRET=                 # openssl rand -hex 32

# Optional — email verification (deferred for v1, set if SMTP available)
# GOL_SMTP_HOST=
# GOL_SMTP_PORT=587
# GOL_SMTP_USER=
# GOL_SMTP_PASSWORD=
# GOL_SMTP_FROM=noreply@example.com

# Debug (set to true for local dev only)
GOL_DEBUG=false
